{
  "name": "lifelong-calendar-reminders",
  "main": "worker.mjs",
  "compatibility_date": "2026-03-06",
  "triggers": {
    "crons": [
      "*/30 * * * *"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lifelong-calendar",
      "database_id": "replace-me"
    }
  ],
  "vars": {
    "PUBLIC_BASE_URL": "https://replace-me.workers.dev"
  }
}
